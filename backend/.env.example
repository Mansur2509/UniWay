# Gemini (backend-only; never exposed to the frontend). Model names must be
# verified for the given key/project before setting them here -- see
# backend/tmp_check_gemini_models.py (gitignored, local-only diagnostic).
# Outside local dev, an unset model name is treated as "not configured"
# rather than silently trying an unverified default.
GEMINI_API_KEY=
AI_ESSAY_SCORING_ENABLED=false
AI_ESSAY_MODEL=
AI_ESSAY_TIMEOUT_SECONDS=30
AI_ESSAY_MAX_OUTPUT_TOKENS=2500
AI_ESSAY_TEMPERATURE=0
AI_PROFILE_ASSESSMENT_ENABLED=false
AI_PROFILE_ASSESSMENT_MODEL=
AI_TIMEOUT_SECONDS=20
AI_MAX_OUTPUT_TOKENS=1200
# Set to false only if the selected model rejects responseSchema (HTTP 400);
# the strict backend validator still runs regardless of this flag.
AI_GEMINI_RESPONSE_SCHEMA_ENABLED=true

