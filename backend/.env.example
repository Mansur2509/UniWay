# Gemini (backend-only; never exposed to the frontend). Single-model policy:
# no fallback, no discovery, no automatic switching. Whatever exact string is
# set below is used verbatim -- verify a candidate model name against a real
# key first with backend/tmp_check_gemini_models.py (gitignored, local-only
# diagnostic) before setting it here. A missing/blank model env var is treated
# as "not configured" (controlled unavailable response), never substituted
# with a different model. `AI_PROFILE_ASSESSMENT_MODEL` is the canonical env
# variable for profile assessment -- do not use `AI_PROFILE_MODEL`.
GEMINI_API_KEY=
AI_PROVIDER=gemini
AI_ESSAY_MODEL=gemini-2.0-lite
AI_PROFILE_ASSESSMENT_MODEL=gemini-2.0-lite
AI_ESSAY_SCORING_ENABLED=true
AI_PROFILE_ASSESSMENT_ENABLED=true
AI_ESSAY_TIMEOUT_SECONDS=30
AI_ESSAY_MAX_OUTPUT_TOKENS=2500
AI_ESSAY_TEMPERATURE=0
AI_TIMEOUT_SECONDS=20
AI_MAX_OUTPUT_TOKENS=1200
# Set to false only if the selected model rejects responseSchema (HTTP 400);
# the strict backend validator still runs regardless of this flag.
AI_GEMINI_RESPONSE_SCHEMA_ENABLED=true

